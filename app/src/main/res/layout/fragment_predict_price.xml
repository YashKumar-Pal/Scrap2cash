<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/green_leaves_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Scrap2Cash"
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:background="#2f6709"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Circuit Details"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/productType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Product Type"
                android:background="@drawable/edit_text_bg"
                android:textColor="#ffffff"
                android:textColorHint="#a6cb9d"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Brand"
                android:background="@drawable/edit_text_bg"
                android:textColor="#ffffff"
                android:textColorHint="#a6cb9d"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Build Quality (out of 5)"
                android:inputType="number"
                android:background="@drawable/edit_text_bg"
                android:textColor="#ffffff"
                android:textColorHint="#a6cb9d"
                android:padding="12dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/predictPriceBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Predict Price"
                android:backgroundTint="#a6cb9d"
                android:textColor="#292924" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
