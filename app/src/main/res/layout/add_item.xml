<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"

    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/mainll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/add_itemround"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/update"
            android:layout_gravity="center_horizontal"
            android:text="Add Item"
            android:textColor="#062C03"
            android:textSize="45sp" />

        <EditText
            android:id="@+id/mname"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="10dp"
            android:textColorHint="#EBE2E2"
            android:textColor="#0F0B0B"
            android:backgroundTint="#fff"
            android:background="@drawable/roundededittext"
            android:hint="Enter Model Name"
            android:textSize="30sp" />

        <EditText
            android:id="@+id/cname"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="5dp"
            android:textColor="#0F0B0B"
            android:textColorHint="#EBE2E2"

            android:backgroundTint="#fff"
            android:background="@drawable/roundededittext"
            android:hint="Enter Company Name"
            android:textSize="30sp" />
        <EditText
            android:id="@+id/oprice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="5dp"
            android:textColor="#0F0B0B"
            android:textColorHint="#EBE2E2"
            android:backgroundTint="#fff"
            android:maxEms="7"
            android:inputType="numberDecimal"
            android:background="@drawable/roundededittext"
            android:hint="Enter Original Price"
            android:textSize="30sp" />
        <EditText
            android:id="@+id/uprice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="5dp"
            android:textColor="#0F0B0B"
            android:textColorHint="#EBE2E2"
            android:inputType="numberDecimal"
            android:maxEms="7"
            android:backgroundTint="#fff"
            android:background="@drawable/roundededittext"
            android:hint="Enter Used Price"
            android:textSize="30sp" />
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:id="@+id/itemimg"
            android:clickable="true"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/selectimg" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Click to Choose\n       image"
            android:layout_gravity="center_horizontal"
            android:id="@+id/chooseimg"
            android:textColor="#000"/>

        <Button
            android:id="@+id/additem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="#0F0B0B"
            android:layout_gravity="center_horizontal"
            android:text="Add Item"/>




    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>