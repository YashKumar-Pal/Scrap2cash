<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <!-- Repeat this CardView for each item -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="15dp"
            android:background="#fff"
            app:cardElevation="6dp">
           <LinearLayout
               android:layout_width="match_parent"
               android:layout_height="match_parent"
               android:orientation="horizontal"
               android:descendantFocusability="blocksDescendants"
               android:clickable="true"
               android:focusable="false"
               android:id="@+id/acardmainll">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_weight="1"
                android:background="#fff"
                android:padding="16dp">
               <LinearLayout
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal">
                <TextView
                    android:id="@+id/itemName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />
                   <TextView
                       android:id="@+id/modelName2"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text=" HP Pavilion"
                       android:textSize="18sp"
                       android:textStyle="bold"
                       android:textColor="#000000" />
               </LinearLayout>
               <LinearLayout
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal">
                <TextView
                    android:id="@+id/companyName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Company:"
                    android:textSize="16sp"
                    android:textColor="#2F2D2D"
                    android:layout_marginTop="4dp" />
                   <TextView
                       android:id="@+id/companyName2"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="HP"
                       android:textSize="16sp"
                       android:textColor="#2F2D2D"
                       android:layout_marginTop="4dp" />
               </LinearLayout>
               <LinearLayout
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal">
                <TextView
                    android:id="@+id/originalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Original Price: ₹"
                    android:textSize="16sp"
                    android:textColor="#FF6200EE"
                    android:layout_marginTop="4dp" />
                   <TextView
                       android:id="@+id/originalPrice2"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="55,000"
                       android:textSize="16sp"
                       android:textColor="#FF6200EE"
                       android:layout_marginTop="4dp" />
               </LinearLayout>
               <LinearLayout
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal">
                <TextView
                    android:id="@+id/usedPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Used Price: ₹"
                    android:textSize="16sp"
                    android:textColor="#FF0000"
                    android:layout_marginTop="4dp" />
                   <TextView
                       android:id="@+id/usedPrice2"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="32,000"
                       android:textSize="16sp"
                       android:textColor="#FF0000"
                       android:layout_marginTop="4dp" />
               </LinearLayout>

                <CheckBox
                    android:id="@+id/sellLater"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mark for future sale"
                    android:layout_marginTop="8dp"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:textColor="#000000" />
            </LinearLayout>
               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="match_parent"
                   android:background="@android:color/transparent"
                   android:layout_weight="2"
                   >
                   <ImageView
                       android:layout_width="match_parent"
                       android:layout_height="match_parent"
                       android:layout_marginTop="8dp"
                       android:layout_marginRight="8dp"
                       android:layout_marginLeft="8dp"
                       android:layout_marginBottom="8dp"
                       android:background="@android:color/transparent"
                       android:id="@+id/mainimg"
                       android:src="@drawable/user_image_account_box_24"/>
               </LinearLayout>
           </LinearLayout>
        </androidx.cardview.widget.CardView>
</LinearLayout>