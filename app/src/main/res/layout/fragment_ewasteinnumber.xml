<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.ewasteinnumber.ewasteinnumberFragment">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:background="@drawable/fragmentroundbackground_bn">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="E-Waste Statistics"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="12dp"/>

            <!-- Global Stats -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌍 Global E-Waste (2022)\n• Total: 62 billion kg\n• Per Capita: 7.8 kg/year\n• Recycled: 22.3%\n• Projected 2030: 82 billion kg"
                android:textSize="16sp"
                android:textColor="#180000"
                android:layout_marginBottom="16dp"/>

            <!-- India Stats -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🇮🇳 India’s E-Waste (2023–24)\n• Total: 1.751 million metric tons\n• Growth: 73% in 5 years\n• Recycled: 43%\n• Unprocessed: 990,000 metric tons"
                android:textSize="16sp"
                android:textColor="#180000"
                android:layout_marginBottom="16dp"/>
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/statistics"
                android:src="@drawable/ewastestatistics"
                />
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/statistics2"
                android:src="@drawable/bycountry_statistics"
                />


        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>